FLASK_SECRET_KEY=replace-with-random-secret
AWS_DEFAULT_REGION=ap-northeast-2
S3_BUCKET_NAME=cloudsec-corp-storage-0501
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here

# Database configuration
DB_TYPE=sqlite            # sqlite / postgresql / mysql
DB_HOST=localhost         # RDS endpoint or DB server host
DB_PORT=5432              # 포스트그레스 기본 포트 5432, MySQL 기본 포트 3306
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=cloudsec_app
DB_PATH=instance/metadata.db  # sqlite 전용 경로

APP_DEFAULT_USERNAME=admin
APP_DEFAULT_PASSWORD=ChangeMe123!
